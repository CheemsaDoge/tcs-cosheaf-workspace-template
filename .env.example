# Example provider-related variable names only. Do not put secrets in this file.

# Optional framework install source for provider smoke demos.
COSHEAF_FRAMEWORK_REF=main
COSHEAF_SKIP_INSTALL=0
COSHEAF_CMD=
COSHEAF_PROVIDER_SMOKE_ISSUE=issue.example-private-claim
COSHEAF_PROVIDER_SMOKE_OUTPUT_DIR=.cosheaf/provider-fake-smoke

# Real provider variables, if a user explicitly enables a provider locally.
# Leave values empty in the repository.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
