# Example provider-related variable names only. Do not put secrets in this file.

# Optional framework install source for provider smoke demos. Leave blank to
# use script defaults.
COSHEAF_FRAMEWORK_REF=
COSHEAF_SKIP_INSTALL=
COSHEAF_CMD=
COSHEAF_PROVIDER_SMOKE_ISSUE=
COSHEAF_PROVIDER_SMOKE_OUTPUT_DIR=

# Real provider variable names, if a user explicitly enables a provider
# locally. Leave values empty in the repository. Put real values only in the
# shell, a local secret manager, or an untracked local environment file.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
